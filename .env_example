# Active model — set MODEL to the provider:model string for your chosen backend
MODEL=google_genai:gemini-2.5-flash
MODEL_BASE_URL=

# ── Gemini (cloud) ────────────────────────────────────────────────────────────
# MODEL=google_genai:gemini-2.5-flash
# MODEL_BASE_URL=
GOOGLE_API_KEY=your-gemini-api-key

# ── Ollama (local) ────────────────────────────────────────────────────────────
# Minimum requirement: model must support tool calling.
# Small models (1b–2b) and most Gemma variants do NOT support tools reliably.
# Recommended minimum: 7b+ with explicit tool-calling support.
# MODEL_BASE_URL=http://localhost:11434

# Best tool-calling support (recommended for local use, fits in 8 GB RAM):
# MODEL=ollama:qwen2.5:7b

# Lighter option (~2.5 GB RAM), good tool calling:
# MODEL=ollama:qwen2.5:3b

# Good tool calling, widely supported:
# MODEL=ollama:llama3.1:8b
# MODEL=ollama:mistral:7b

# Borderline — 3b is much better than 1b but not guaranteed:
# MODEL=ollama:llama3.2:3b

# ── Ollama — Gemma variants ───────────────────────────────────────────────────
# Only Gemma 4 supports tool calling; Gemma 3 / Gemma 2 / Gemma do NOT.
# gemma4:e2b (2b) — tool calling unreliable in practice, conversation quality poor
# gemma4:26b   — fits 16 GB RAM but will max it out; very slow
# gemma4:31b   — requires ~20 GB RAM, too large for most consumer machines
# MODEL=ollama:gemma4:e2b
# MODEL_BASE_URL=http://localhost:11434

# ── Models known NOT to work ──────────────────────────────────────────────────
# llama3.2:1b  — too small, tool calling broken
# gemma3, gemma2, gemma (all variants) — no tool calling support
