# Active model — set MODEL to the provider:model string for your chosen backend
MODEL=google_genai:gemini-2.5-flash
MODEL_BASE_URL=

# ── Gemini (cloud) ────────────────────────────────────────────────────────────
# MODEL=google_genai:gemini-2.5-flash
# MODEL_BASE_URL=
GOOGLE_API_KEY=your-gemini-api-key

# ── Ollama (local) ────────────────────────────────────────────────────────────
# Must be a model that supports tool-calling (e.g. llama3.2, qwen2.5, mistral-nemo)
# gemma3 does NOT support tools and will fail at runtime.
# MODEL=ollama:llama3.2:1b
# MODEL_BASE_URL=http://localhost:11434

# ── Ollama — gemma4:e2b example ───────────────────────────────────────────────
# MODEL=ollama:gemma4:e2b
# MODEL_BASE_URL=http://localhost:11434
